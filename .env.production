# App base (assets and wallet_api.php are under the same path). Must end with /.
VITE_APP_BASE=/

# Shared theme CSS/JS/fonts: must be a full URL (https://host/...). Required for Minia theme styles.
VITE_COMMON_ASSETS=https://main1.phpcoin.net/apps/common

# Main host (node api.php, explorer, verifier dapps origin): https://host — no trailing slash.
VITE_MAIN_URL=https://main1.phpcoin.net

# Wallet backend — full URL to wallet_api.php (getPrice, test). Loaded directly by the browser.
VITE_WALLET_API_URL=https://wallet.phpcoin.net/wallet_api.php
