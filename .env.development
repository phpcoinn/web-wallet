# App base (must end with /). Assets and wallet_api.php are under the same path.
VITE_APP_BASE=/

# Shared theme CSS/JS/fonts: must be a full URL (https://host/...). Loaded directly by the browser, not via Vite proxy.
VITE_COMMON_ASSETS=https://main1.phpcoin.net/apps/common

# Main host (node api.php, explorer, verifier dapps origin): https://host — no trailing slash.
VITE_MAIN_URL=https://main1.phpcoin.net

# Wallet backend — full URL to wallet_api.php (required).
VITE_WALLET_API_URL=https://wallet.phpcoin.net/wallet_api.php
